#!/usr/bin/env bash
# tmux-inject - Send text + Enter to a tmux pane with proper timing.
set -euo pipefail
if [[ $# -lt 2 ]]; then
  echo "Usage: tmux-inject <pane-id> <text>" >&2
  exit 1
fi
PANE="$1"
shift
TEXT="$*"
tmux send-keys -t "$PANE" -l "$TEXT"
CHAR_COUNT=$(printf '%s' "$TEXT" | wc -c)
EXTRA=$(( CHAR_COUNT / 200 ))
SLEEP=$(echo "0.5 + $EXTRA * 0.1" | bc)
[[ $(echo "$SLEEP > 3.0" | bc) -eq 1 ]] && SLEEP=3.0
sleep "$SLEEP"
tmux send-keys -t "$PANE" Enter
